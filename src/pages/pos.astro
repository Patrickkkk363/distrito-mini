---
// src/pages/pos.astro
import Layout from '../layouts/BaseLayout.astro';
---

<Layout title="Punto de Venta | Distrito Mini 🧸">
  <div class="min-h-screen bg-slate-50 font-sans text-black">
    
    <nav class="bg-white border-b p-4 shadow-sm flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center gap-2">
            <span class="text-2xl">🧸</span>
            <h1 class="text-2xl font-black text-emerald-600">Distrito Mini <span class="text-slate-400 font-medium">POS</span></h1>
        </div>
        <div class="flex gap-4 items-center">
            <a href="/" class="text-slate-500 font-bold hover:text-emerald-600 transition-colors">Inicio</a>
            <button id="btn-logout-pos" class="bg-slate-100 text-slate-600 px-4 py-2 rounded-lg font-bold hover:bg-red-50 hover:text-red-600 transition-all">Salir</button>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <div class="lg:col-span-2">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-slate-800">Productos</h2>
            <span id="items-count" class="bg-slate-200 text-slate-600 px-3 py-1 rounded-full text-xs font-bold">Cargando...</span>
        </div>
        
        <div id="grid-products" class="grid grid-cols-2 md:grid-cols-3 gap-4">
           <div class="col-span-full text-center py-20 text-slate-400 italic font-medium">
             Buscando productos en el inventario...
           </div>
        </div>
      </div>

      <div class="lg:col-span-1">
        <div class="bg-white rounded-3xl shadow-xl p-6 border border-slate-200 sticky top-24">
          <h2 class="text-2xl font-black text-slate-800 mb-6 flex items-center gap-2">
            Carrito 🛒
          </h2>
          
          <div id="cart-items" class="space-y-3 mb-6 max-h-[450px] overflow-y-auto pr-2">
            <div class="text-center py-10">
                <span class="text-4xl block mb-2">📥</span>
                <p class="text-slate-400 font-medium">Tu carrito está vacío</p>
            </div>
          </div>

          <div class="border-t border-dashed pt-4 space-y-3">
            <div class="flex justify-between text-slate-500 font-medium">
              <span>Subtotal</span>
              <span id="subtotal">S/ 0.00</span>
            </div>
            <div class="flex justify-between text-3xl font-black text-slate-900 pt-2 border-t">
              <span>Total</span>
              <span id="total">S/ 0.00</span>
            </div>
          </div>

          <button id="btn-pay" disabled class="w-full bg-emerald-500 hover:bg-emerald-600 disabled:bg-slate-200 disabled:text-slate-400 text-white font-black py-5 rounded-2xl mt-8 shadow-lg shadow-emerald-500/20 transition-all transform active:scale-95 text-lg">
            CONFIRMAR VENTA
          </button>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  // --- 1. SEGURIDAD: VERIFICAR SESIÓN ---
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    window.location.href = '/login';
  }

  let cart: any[] = [];
  let allProducts: any[] = [];

  // --- 2. CARGAR PRODUCTOS ---
  async function loadPOS() {
    const { data: products, error } = await supabase
        .from('products')
        .select('*')
        .gt('stock', 0)
        .order('name', { ascending: true });

    const grid = document.getElementById('grid-products');
    const count = document.getElementById('items-count');
    
    if (!grid || error) return;

    allProducts = products || [];
    if (count) count.innerText = `${allProducts.length} disponibles`;

    if (allProducts.length === 0) {
        grid.innerHTML = `<div class="col-span-full text-center py-20">No hay productos con stock.</div>`;
        return;
    }

    grid.innerHTML = allProducts.map(p => `
      <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all">
        <div class="flex justify-between items-start mb-2">
            <span class="text-2xl text-black">📦</span>
            <span class="bg-emerald-50 text-emerald-600 px-2 py-1 rounded-lg text-[10px] font-black uppercase tracking-tighter">Disponible</span>
        </div>
        <h3 class="font-bold text-slate-800 text-black leading-tight h-10 overflow-hidden mb-1">${p.name}</h3>
        <p class="text-2xl font-black text-slate-900 text-black mb-1">S/ ${parseFloat(p.price).toFixed(2)}</p>
        <p class="text-xs font-bold text-slate-400 text-black mb-4 uppercase">Stock: ${p.stock}</p>
        
        <button 
          data-id="${p.id}" 
          class="add-btn w-full bg-slate-900 text-white py-3 rounded-xl font-bold text-sm hover:bg-emerald-500 transition-colors shadow-lg active:scale-95"
        >
            AGREGAR +
        </button>
      </div>
    `).join('');

    // Listener para los botones
    document.querySelectorAll('.add-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const id = parseInt((e.currentTarget as HTMLElement).getAttribute('data-id') || '0');
            addToCart(id);
        });
    });
  }

  // --- 3. LOGICA DEL CARRITO ---
  function addToCart(id: number) {
    const product = allProducts.find(p => p.id === id);
    const itemInCart = cart.find(item => item.id === id);

    if (itemInCart) {
        if (itemInCart.qty < product.stock) {
            itemInCart.qty++;
        } else {
            alert("¡No hay más unidades en stock!");
        }
    } else {
        cart.push({ ...product, qty: 1 });
    }
    renderCart();
  }

  function renderCart() {
    const container = document.getElementById('cart-items');
    const totalEl = document.getElementById('total');
    const subtotalEl = document.getElementById('subtotal');
    const btnPay = document.getElementById('btn-pay') as HTMLButtonElement;

    if (!container || !totalEl || !subtotalEl) return;

    if (cart.length === 0) {
        container.innerHTML = '<div class="text-center py-10 text-slate-400">Carrito vacío</div>';
        btnPay.disabled = true;
    } else {
        container.innerHTML = cart.map(item => `
            <div class="flex justify-between items-center bg-slate-50 p-4 rounded-2xl border border-slate-100">
                <div class="flex flex-col">
                    <span class="font-bold text-slate-800 text-black text-sm">${item.name}</span>
                    <span class="text-xs text-slate-500 text-black">${item.qty} x S/ ${item.price.toFixed(2)}</span>
                </div>
                <span class="font-black text-slate-900 text-black text-sm">S/ ${(item.qty * item.price).toFixed(2)}</span>
            </div>
        `).join('');
        btnPay.disabled = false;
    }

    const total = cart.reduce((acc, item) => acc + (item.qty * item.price), 0);
    totalEl.innerText = `S/ ${total.toFixed(2)}`;
    subtotalEl.innerText = `S/ ${total.toFixed(2)}`;
  }

  // --- 4. FINALIZAR VENTA (RESTAR STOCK) ---
  document.getElementById('btn-pay')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-pay') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerText = "PROCESANDO...";

    try {
        for (const item of cart) {
            const { error } = await supabase
                .from('products')
                .update({ stock: item.stock - item.qty })
                .eq('id', item.id);
            if (error) throw error;
        }

        alert("¡Venta completada con éxito! 🎉");
        cart = [];
        renderCart();
        loadPOS(); // Recargar productos para ver el nuevo stock
    } catch (err) {
        alert("Hubo un error al procesar el pago");
        console.error(err);
    } finally {
        btn.innerText = "CONFIRMAR VENTA";
    }
  });

  // LOGOUT
  document.getElementById('btn-logout-pos')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/login';
  });

  // Arrancamos
  loadPOS();
</script>